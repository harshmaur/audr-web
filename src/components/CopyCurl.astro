---
const cmd = "curl -fsSL https://audr.dev/install.sh | sh";
---

<div class="flex items-stretch border border-border bg-surface font-mono text-sm">
  <pre
    class="flex-1 px-4 py-3 m-0 overflow-x-auto text-text"
    data-copy-source>{cmd}</pre>
  <button
    type="button"
    class="px-4 py-3 border-l border-border text-text-muted hover:text-text hover:bg-surface-2 uppercase tracking-wider text-xs"
    aria-label="Copy install command to clipboard"
    data-copy-button
  >
    Copy
  </button>
</div>

<script is:inline>
  (function () {
    const btn = document.querySelector("[data-copy-button]");
    const src = document.querySelector("[data-copy-source]");
    if (!btn || !src) return;
    btn.addEventListener("click", async () => {
      const text = src.textContent ?? "";
      try {
        await navigator.clipboard.writeText(text);
        btn.textContent = "Copied";
        setTimeout(() => (btn.textContent = "Copy"), 1400);
      } catch {
        btn.textContent = "Press ⌘C";
        setTimeout(() => (btn.textContent = "Copy"), 1800);
      }
    });
  })();
</script>
