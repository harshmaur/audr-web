---
import type { CVE } from "../lib/types";
import CopyCurl from "./CopyCurl.astro";

interface Props {
  cve: CVE;
}

const { cve } = Astro.props;
const subhead = `audr is an offline, single-binary scanner for AI agent configs — Claude Code, Cursor, Codex CLI, Windsurf, MCP servers. Run it on a laptop, get an HTML report. CISO-shaped, dev-deployable.`;
---

<section class="max-w-page mx-auto px-6 md:px-8 pt-6 md:pt-12 pb-12 md:pb-16">
  <h1
    class="font-mono font-medium leading-tight text-text max-w-h1"
    style="font-size: clamp(28px, 4.4vw, 50px); letter-spacing: -0.01em;"
  >
    <span>{cve.product} is on every laptop your team owns.</span>
    <br />
    <span>
      <span class="text-sev-critical">{cve.cve_id}</span> means {cve.visceral_consequence}.
    </span>
    <br />
    <span>Audr finds {cve.scope_phrase}.</span>
  </h1>

  <p class="mt-8 max-w-sub text-text-muted" style="font-size: 1.125rem; line-height: 1.55;">
    {subhead}
  </p>

  <div class="mt-10 flex flex-col md:flex-row items-stretch md:items-center gap-4">
    <CopyCurl />
    <a
      href="/sample-report"
      class="font-sans font-medium text-sm text-text border border-text px-4 py-3 no-underline hover:bg-text hover:text-bg transition-colors"
      data-cta="sample-report"
    >
      View sample report →
    </a>
  </div>

  <p class="mt-3 font-mono text-xs text-text-muted">
    Or read the <a href="https://github.com/harshmaur/audr">README</a> ·
    <a href="/security">/security</a>
  </p>
</section>
