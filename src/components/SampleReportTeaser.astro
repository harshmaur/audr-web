---
const stats = [
  { label: "laptops scanned", value: "200", color: "text-text" },
  { label: "critical findings", value: "14", color: "text-sev-critical" },
  { label: "attack chains", value: "5", color: "text-sev-high" },
  { label: "scan time", value: "4.2s", color: "text-sev-ok" },
];
---

<section class="audr-rule">
  <div class="max-w-page mx-auto px-6 md:px-8 py-12 md:py-16">
    <header class="mb-6">
      <p class="font-mono text-xs text-text-muted uppercase tracking-wider">
        what a real scan looks like
      </p>
      <h2 class="font-sans font-semibold text-2xl mt-2">
        Forensic HTML report. Redacted excerpt — 200 dev laptops, real findings.
      </h2>
      <p class="font-sans text-base text-text-muted mt-2 max-w-narrow">
        audr emits an HTML report you can forward up the chain. Each finding has a one-line
        attacker-gets, a file:line citation, and lands on the Attack Chain it belongs to.
      </p>
    </header>

    <div class="border border-border bg-surface">
      <div class="border-b border-border px-5 py-3 flex items-baseline gap-3 font-mono text-xs">
        <span class="text-text-muted">audr scan</span>
        <span class="text-text-muted">·</span>
        <span class="text-text-muted">redacted excerpt</span>
        <span class="text-text-muted">·</span>
        <span class="text-text">200 dev laptops</span>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 border-b border-border">
        {
          stats.map((s) => (
            <div class="border-r border-border last:border-r-0 px-5 py-5">
              <p
                class={`font-mono font-medium ${s.color}`}
                style="font-size: 1.75rem; font-variant-numeric: tabular-nums;"
              >
                {s.value}
              </p>
              <p class="font-mono text-[11px] text-text-muted uppercase tracking-wider mt-1">
                {s.label}
              </p>
            </div>
          ))
        }
      </div>
      <div class="px-5 py-5">
        <a
          href="/sample-report"
          class="font-sans font-medium text-sm border border-text px-4 py-3 no-underline inline-block hover:bg-text hover:text-bg transition-colors"
        >
          Open the full sample report →
        </a>
      </div>
    </div>
  </div>
</section>
