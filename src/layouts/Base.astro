---
import "../styles/globals.css";

interface Props {
  title: string;
  description: string;
  /**
   * Set true on /404 to suppress analytics — no telemetry on error pages.
   */
  noAnalytics?: boolean;
}

const { title, description, noAnalytics = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, "https://audr.dev").href;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark light" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icon-180.png" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://audr.dev/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://audr.dev/og.png" />

    <script is:inline>
      // Honor a previously chosen theme without a flash of the default one.
      // Default state is dark per design system; respect the user's choice once set.
      try {
        const saved = localStorage.getItem("audr-theme");
        if (saved === "light" || saved === "dark") {
          document.documentElement.dataset.theme = saved;
        }
      } catch (_) {
        /* localStorage may be blocked in private browsing — fall through to dark */
      }
    </script>

    {
      !noAnalytics && (
        <script
          is:inline
          defer
          src="https://api.pirsch.io/pirsch.js"
          data-code="audr-dev-analytics"
        />
      )
    }
  </head>
  <body>
    <slot />
  </body>
</html>
