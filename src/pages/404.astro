---
import Base from "../layouts/Base.astro";
---

<Base
  title="Not found — audr.dev"
  description="Page not found. Run audr scan to find what is."
>
  <main class="max-w-page mx-auto px-6 md:px-8 py-24">
    <p class="font-mono text-xs text-text-muted uppercase tracking-wider">404 · not found</p>
    <h1 class="font-mono font-medium mt-3" style="font-size: clamp(28px, 4.4vw, 50px);">
      Page not found.
      <br />
      Run <code>audr scan</code> to find what is.
    </h1>
    <p class="mt-8 font-mono text-sm">
      <a href="/">/</a> · <a href="/sample-report">/sample-report</a> ·{" "}
      <a href="/security">/security</a>
    </p>
  </main>
</Base>
