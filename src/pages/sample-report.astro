---
// /sample-report is served as the polished HTML at public/sample-report.html.
// Astro's built-in routing prefers public/* over this page, so this file is a
// fallback in case the polish script hasn't run (dev mode, freshly cloned tree).
//
// In production the user actually lands on /sample-report.html (which we link
// as /sample-report from the homepage; Cloudflare Pages will resolve either).

import Base from "../layouts/Base.astro";
---

<Base
  title="Sample fleet scan — audr"
  description="Polished excerpt of an audr fleet scan. Five attack chains, redacted paths, full forensic structure."
>
  <main class="max-w-page mx-auto px-6 md:px-8 py-12">
    <h1 class="font-mono font-medium text-3xl">Sample report not built.</h1>
    <p class="mt-4 max-w-narrow">
      The polished sample report is generated by <code>scripts/polish-sample-report.mjs</code>{" "}
      and lives at <code>public/sample-report.html</code>. Run{" "}
      <code class="font-mono">npm run polish</code> to generate it.
    </p>
    <p class="mt-4">
      <a href="/">← Back to home</a>
    </p>
  </main>
</Base>
