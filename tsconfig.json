{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"]
    },
    "types": ["vitest/globals"]
  },
  "include": ["src", "scripts", "tests"],
  "exclude": ["node_modules", "dist", ".astro", "vendor"]
}
